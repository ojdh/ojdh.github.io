---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import type { GalleryItem } from '../components/PhotoGrid.astro';

// Auto-discover every image in src/assets/photos — drop files in, they appear.
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/photos/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
);

const entries = Object.entries(modules).sort(([a], [b]) => a.localeCompare(b));

const photos: GalleryItem[] = await Promise.all(
  entries.map(async ([path, mod]) => {
    const img = mod.default;
    const name =
      path
        .split('/')
        .pop()
        ?.replace(/\.[^.]+$/, '') ?? 'photo';

    const thumb = await getImage({ src: img, width: 700, format: 'webp' });
    const full = await getImage({
      src: img,
      width: Math.min(img.width, 2000),
      format: 'webp',
    });

    return {
      thumb: thumb.src,
      full: full.src,
      width: full.attributes.width ?? img.width,
      height: full.attributes.height ?? img.height,
      alt: name.replace(/[-_]/g, ' '),
    };
  }),
);
---

<BaseLayout
  title="Photography"
  description="A selection of photographs."
>
  <section class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="font-serif text-4xl font-semibold tracking-tight text-[var(--color-ink)]">
      Photography
    </h1>
    <p class="mt-4 max-w-xl leading-relaxed text-[var(--color-muted)]">
      <!-- TODO: replace the placeholder images in src/assets/photos with your work. -->
      A selection of frames I've made. Click any photo to view it full size.
    </p>

    <div class="mt-10">
      {
        photos.length > 0 ? (
          <PhotoGrid photos={photos} />
        ) : (
          <p class="text-[var(--color-muted)]">
            No photos yet — add images to{' '}
            <code>src/assets/photos/</code>.
          </p>
        )
      }
    </div>
  </section>
</BaseLayout>
