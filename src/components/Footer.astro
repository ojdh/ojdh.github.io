---
import { site } from '../data/site';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[var(--color-faint)]">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-8 text-sm text-[var(--color-muted)] sm:flex-row"
  >
    <p>© {year} {site.name}</p>
    <SocialLinks />
  </div>
</footer>
