---
// Renders an optimized, masonry-style gallery wired for the PhotoSwipe lightbox.
// Each item carries the full-size dimensions PhotoSwipe needs via data attrs.
export interface GalleryItem {
  thumb: string;
  full: string;
  width: number;
  height: number;
  alt: string;
}

interface Props {
  photos: GalleryItem[];
}
const { photos } = Astro.props;
---

<div
  id="gallery"
  class="columns-1 gap-4 sm:columns-2 lg:columns-3 [&>a]:mb-4"
>
  {
    photos.map((p) => (
      <a
        href={p.full}
        data-pswp-width={p.width}
        data-pswp-height={p.height}
        target="_blank"
        rel="noopener noreferrer"
        class="block break-inside-avoid overflow-hidden rounded-lg"
      >
        <img
          src={p.thumb}
          alt={p.alt}
          loading="lazy"
          decoding="async"
          class="w-full transition-transform duration-300 hover:scale-[1.02]"
        />
      </a>
    ))
  }
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  });
  lightbox.init();
</script>
