  const FALLBACK_AVATAR_ICONS = ['🎒', '🥾', '🧭', '🔥', '🌲', '⭐'];

  // Pixel-art matching for Swipe mode: keyword -> icon key, checked in order
  // (most specific first) against the item's name, then category, then
  // group_name. Flavor, not precision — falls back to a generic icon.
  const ITEM_ICON_PATHS: Record<string, string> = {
