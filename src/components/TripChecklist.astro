  function pickItemIconPath(item: Item): string {
    const haystacks = [item.name, item.category, item.group_name].map((s) => s.toLowerCase());
    for (const [keyword, key] of ITEM_ICON_KEYWORDS) {
      if (haystacks.some((h) => h.includes(keyword))) return ITEM_ICON_PATHS[key];
    }
    return ITEM_ICON_PATHS.generic;
  }

  let client: ReturnType<typeof createTripClient> | null = null;
  let items: Item[] = [];
  let assignments: Assignment[] = [];
  let previousAssignmentIds = new Set<string>();
  const collapsedGroups = new Set<string>();
  const selectedItemIds = new Set<string>();
  let activeFilter: string | null = null;
  let activeView: 'checklist' | 'summary' | 'swipe' = 'checklist';

  // --- Swipe mode state ---
  let swipeDeck: Item[] = [];
  let swipeIndex = 0;
  let swipeInitialized = false;
  let swipeBusy = false;

  let myName = localStorage.getItem(NAME_STORAGE_KEY) ?? '';
  let myAvatar = localStorage.getItem(AVATAR_STORAGE_KEY) ?? '';
  let selectedRosterName: string | null = null;
  let selectedAvatar: string | null = null;

  function slugify(s: string) {
    return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  }

  function triggerRainRemoval(el: HTMLElement, assignmentId: string) {
    el.classList.add('camp-removing');
    el.insertAdjacentHTML('beforeend', ' <span>🌧️</span>');
    setTimeout(() => unclaim(assignmentId), 380);
  }

  const gate = document.getElementById('gate')!;
  const gateForm = document.getElementById('gate-form') as HTMLFormElement;
  const gatePasscodeInput = document.getElementById('gate-passcode') as HTMLInputElement;
  const gateError = document.getElementById('gate-error')!;
  const nameStep = document.getElementById('name-step')!;
  const rosterEl = document.getElementById('name-roster')!;
  const otherInput = document.getElementById('name-other-input') as HTMLInputElement;
  const avatarPickerEl = document.getElementById('avatar-picker')!;
  const nameStepContinue = document.getElementById('name-step-continue') as HTMLButtonElement;
  const app = document.getElementById('app')!;
  const identityDisplay = document.getElementById('identity-display')!;
  const identityChangeBtn = document.getElementById('identity-change') as HTMLButtonElement;
  const filterBarEl = document.getElementById('filter-bar')!;
  const bulkBar = document.getElementById('bulk-bar')!;
  const bulkCount = document.getElementById('bulk-count')!;
  const bulkNoteInput = document.getElementById('bulk-note') as HTMLInputElement;
  const bulkClaimBtn = document.getElementById('bulk-claim-btn') as HTMLButtonElement;
  const bulkClearBtn = document.getElementById('bulk-clear-btn') as HTMLButtonElement;
  const groupsEl = document.getElementById('groups')!;
  const viewChecklist = document.getElementById('view-checklist')!;
  const viewSummary = document.getElementById('view-summary')!;
  const viewSwipe = document.getElementById('view-swipe')!;
  const swipeProgress = document.getElementById('swipe-progress')!;
  const swipeAddBtn = document.getElementById('swipe-add-btn') as HTMLButtonElement;
  const swipeAddForm = document.getElementById('swipe-add-form') as HTMLFormElement;
  const swipeAddInput = document.getElementById('swipe-add-input') as HTMLInputElement;
  const swipeStack = document.getElementById('swipe-stack')!;
  const swipeActions = document.getElementById('swipe-actions')!;
  const swipeNopeBtn = document.getElementById('swipe-nope-btn') as HTMLButtonElement;
  const swipeYesBtn = document.getElementById('swipe-yes-btn') as HTMLButtonElement;
  const swipeEnd = document.getElementById('swipe-end')!;
  const swipeRestartBtn = document.getElementById('swipe-restart-btn') as HTMLButtonElement;

  // --- Name / avatar onboarding ---

  function currentSelectedName(): string {
    return selectedRosterName === 'OTHER' ? otherInput.value.trim() : selectedRosterName ?? '';
  }

  function updateContinueState() {
    nameStepContinue.disabled = !currentSelectedName() || !selectedAvatar;
  }

  function refreshRosterHighlight() {
    rosterEl.querySelectorAll('button').forEach((btn) => {
      const isOther = btn.textContent === 'Other';
      btn.dataset.selected = String(
        (isOther && selectedRosterName === 'OTHER') || (!isOther && btn.textContent === selectedRosterName)
      );
    });
  }

  function refreshAvatarHighlight() {
    avatarPickerEl.querySelectorAll('button').forEach((btn) => {
      btn.dataset.selected = String(btn.dataset.avatarSrc === selectedAvatar);
    });
  }

  function buildNameStep() {
    for (const name of NAME_ROSTER) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = name;
      btn.addEventListener('click', () => {
        selectedRosterName = name;
        otherInput.classList.add('hidden');
        otherInput.value = '';
        refreshRosterHighlight();
        updateContinueState();
      });
      rosterEl.appendChild(btn);
    }
    const otherBtn = document.createElement('button');
    otherBtn.type = 'button';
    otherBtn.textContent = 'Other';
    otherBtn.addEventListener('click', () => {
      selectedRosterName = 'OTHER';
      otherInput.classList.remove('hidden');
      otherInput.focus();
      refreshRosterHighlight();
      updateContinueState();
    });
    rosterEl.appendChild(otherBtn);

    for (const avatar of AVATAR_OPTIONS) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.dataset.avatarSrc = avatar;
      const img = document.createElement('img');
      img.src = avatar;
      img.alt = '';
      img.className = 'camp-avatar-img';
      btn.appendChild(img);
      btn.addEventListener('click', () => {
        selectedAvatar = avatar;
        refreshAvatarHighlight();
        updateContinueState();
      });
      avatarPickerEl.appendChild(btn);
    }

    otherInput.addEventListener('input', updateContinueState);
  }

  function openNameStep() {
    selectedRosterName = NAME_ROSTER.includes(myName) ? myName : myName ? 'OTHER' : null;
    selectedAvatar = myAvatar || null;
    if (selectedRosterName === 'OTHER') {
      otherInput.value = myName;
      otherInput.classList.remove('hidden');
    } else {
      otherInput.value = '';
      otherInput.classList.add('hidden');
    }
    refreshRosterHighlight();
    refreshAvatarHighlight();
    updateContinueState();
    gate.classList.add('hidden');
    app.classList.add('hidden');
    nameStep.classList.remove('hidden');
  }

  nameStepContinue.addEventListener('click', () => {
    const name = currentSelectedName();
    if (!name || !selectedAvatar) return;
    myName = name;
    myAvatar = selectedAvatar;
    localStorage.setItem(NAME_STORAGE_KEY, myName);
    localStorage.setItem(AVATAR_STORAGE_KEY, myAvatar);
    nameStep.classList.add('hidden');
    showApp();
    render();
  });

  identityChangeBtn.addEventListener('click', () => openNameStep());

  buildNameStep();

  // --- Passcode gate ---

  async function tryEnter(passcode: string) {
    try {
      const candidate = createTripClient(passcode);
      const { data, error } = await candidate.from('items').select('*').order('sort_order');
      // RLS silently returns zero rows (not an error) for a wrong passcode,
      // so an empty result is our signal to reject rather than a real error.
      if (error || !data || data.length === 0) {
        return false;
      }
      client = candidate;
      items = data as Item[];
      storePasscode(passcode);
      await refreshAssignments();
      gate.classList.add('hidden');
      if (myName && myAvatar) {
        showApp();
      } else {
        openNameStep();
      }
    } catch {
      return false;
    }
    return true;
  }

  async function refreshAssignments() {
    if (!client) return;
    const { data } = await client.from('assignments').select('*');
    assignments = (data as Assignment[]) ?? [];
    render();
    previousAssignmentIds = new Set(assignments.map((a) => a.id));
  }

  function showApp() {
    identityDisplay.innerHTML = '';
    if (myAvatar) {
      appendAvatar(identityDisplay, myAvatar, 'camp-avatar-icon');
    }
    identityDisplay.appendChild(document.createTextNode(myName));
    gate.classList.add('hidden');
    nameStep.classList.add('hidden');
    app.classList.remove('hidden');
  }

  gateForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const ok = await tryEnter(gatePasscodeInput.value);
    if (!ok) {
      gateError.textContent = '🚫 Wrong passcode — try again.';
      gateError.classList.remove('hidden');
    }
  });

  document.querySelectorAll<HTMLButtonElement>('.camp-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll<HTMLButtonElement>('.camp-tab').forEach((b) => (b.dataset.active = 'false'));
      btn.dataset.active = 'true';
      const view = (btn.dataset.view ?? 'checklist') as 'checklist' | 'summary' | 'swipe';
      activeView = view;
      viewChecklist.classList.toggle('hidden', view !== 'checklist');
      viewSummary.classList.toggle('hidden', view !== 'summary');
      viewSwipe.classList.toggle('hidden', view !== 'swipe');
      if (view === 'swipe') {
        if (!swipeInitialized) startSwipeDeck();
        else renderSwipeMode();
      }
    });
  });

  // --- Claiming ---

  async function claimItem(itemId: string, note: string) {
    if (!myName || !client) return;
    await client.from('assignments').insert({ item_id: itemId, person_name: myName, avatar: myAvatar, note: note || null });
    await refreshAssignments();
  }

  async function unclaim(assignmentId: string) {
    if (!client) return;
    await client.from('assignments').delete().eq('id', assignmentId);
    await refreshAssignments();
  }

  function updateBulkBar() {
    const count = selectedItemIds.size;
    bulkBar.classList.toggle('hidden', count === 0);
    bulkCount.textContent = `${count} selected`;
  }

  bulkClaimBtn.addEventListener('click', async () => {
    if (!client || !myName || selectedItemIds.size === 0) return;
    const note = bulkNoteInput.value.trim();
    const rows = Array.from(selectedItemIds).map((itemId) => ({
      item_id: itemId,
      person_name: myName,
      avatar: myAvatar,
      note: note || null,
    }));
    await client.from('assignments').insert(rows);
    selectedItemIds.clear();
    bulkNoteInput.value = '';
    updateBulkBar();
    await refreshAssignments();
  });

  bulkClearBtn.addEventListener('click', () => {
    selectedItemIds.clear();
    updateBulkBar();
    render();
  });

  // --- Items: add / edit / remove ---

  async function removeItem(item: Item) {
    if (!client) return;
    await client.from('items').delete().eq('id', item.id);
    items = items.filter((i) => i.id !== item.id);
    assignments = assignments.filter((a) => a.item_id !== item.id);
    render();
  }

  function startEditingItem(item: Item, nameSpan: HTMLElement) {
    const input = document.createElement('input');
    input.type = 'text';
    input.value = item.name;
    input.className = 'camp-input camp-input--sm';
    let finished = false;
    const finish = async (save: boolean) => {
      if (finished) return;
      finished = true;
      const newName = input.value.trim();
      input.replaceWith(nameSpan);
      if (save && client && newName && newName !== item.name) {
        await client.from('items').update({ name: newName }).eq('id', item.id);
        item.name = newName;
        nameSpan.textContent = newName;
      }
    };
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') finish(true);
      if (e.key === 'Escape') finish(false);
    });
    input.addEventListener('blur', () => finish(true));
    nameSpan.replaceWith(input);
    input.focus();
    input.select();
  }

  async function addItem(groupName: string, category: string, name: string) {
    if (!client || !name) return;
    const sortOrder = items.reduce((max, i) => Math.max(max, i.sort_order), 0) + 1;
    const { data } = await client
      .from('items')
      .insert({ group_name: groupName, category, name, sort_order: sortOrder })
      .select();
    if (data) items.push(...(data as Item[]));
    render();
  }

  // --- Rendering ---

  function render() {
    renderChecklist();
    renderSummary();
    if (activeView === 'swipe') renderSwipeMode();
  }

  function escapeHtml(s: string) {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  // Assignments made before the pixel-art avatars shipped stored an emoji
  // character directly; new ones store an image path. Render either.
  function appendAvatar(container: HTMLElement, avatar: string, className: string) {
    if (avatar.startsWith('/')) {
      const img = document.createElement('img');
      img.src = avatar;
      img.alt = '';
      img.className = className;
      container.appendChild(img);
    } else {
      container.appendChild(document.createTextNode(avatar));
    }
  }

  function renderFilterBar(groupNames: string[]) {
    filterBarEl.innerHTML = '';
    const allBtn = document.createElement('button');
    allBtn.type = 'button';
    allBtn.textContent = 'All';
    allBtn.className = 'camp-filter' + (activeFilter === null ? ' camp-filter--active' : '');
    allBtn.addEventListener('click', () => {
      activeFilter = null;
      render();
    });
    filterBarEl.appendChild(allBtn);

    for (const groupName of groupNames) {
      const icon = GROUP_ICONS[groupName] ?? '🏕️';
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = `${icon} ${groupName}`;
      btn.className = 'camp-filter' + (activeFilter === groupName ? ' camp-filter--active' : '');
      btn.addEventListener('click', () => {
        activeFilter = activeFilter === groupName ? null : groupName;
        if (activeFilter) collapsedGroups.delete(activeFilter);
        render();
      });
      filterBarEl.appendChild(btn);
    }
  }

  function renderChecklist() {
    groupsEl.innerHTML = '';
    const allGroupNames = Array.from(new Set(items.map((i) => i.group_name))).sort(
      (a, b) => GROUP_ORDER.indexOf(a) - GROUP_ORDER.indexOf(b)
    );
    renderFilterBar(allGroupNames);
    const groupNames = activeFilter ? allGroupNames.filter((g) => g === activeFilter) : allGroupNames;

    groupNames.forEach((groupName, groupIndex) => {
      const groupId = `group-${slugify(groupName)}`;
      const icon = GROUP_ICONS[groupName] ?? '🏕️';

      if (groupIndex > 0) groupsEl.appendChild(document.createElement('hr')).className = 'camp-trail';

      const groupItems = items.filter((i) => i.group_name === groupName);
      const groupSection = document.createElement('details');
      groupSection.className = 'camp-group';
      groupSection.id = groupId;
      groupSection.open = !collapsedGroups.has(groupName);
      groupSection.addEventListener('toggle', () => {
        if (groupSection.open) collapsedGroups.delete(groupName);
        else collapsedGroups.add(groupName);
      });

      const heading = document.createElement('summary');
      heading.className = 'camp-group__badge';
      heading.innerHTML = `<span class="camp-chevron">▸</span><span class="camp-group__icon">${icon}</span> ${escapeHtml(groupName)}`;
      groupSection.appendChild(heading);

      const categories = Array.from(new Set(groupItems.map((i) => i.category)));
      for (const category of categories) {
        const categoryItems = groupItems.filter((i) => i.category === category);
        if (category !== groupName) {
          const catHeading = document.createElement('h3');
          catHeading.className = 'camp-category';
          catHeading.textContent = `${CATEGORY_ICONS[category] ?? ''} ${category}`.trim();
          groupSection.appendChild(catHeading);
        }
        const list = document.createElement('ul');
        list.className = 'space-y-0';
        for (const item of categoryItems) {
          list.appendChild(renderItemRow(item));
        }
        list.appendChild(renderAddRow(groupName, category));
        groupSection.appendChild(list);
      }
      groupsEl.appendChild(groupSection);
    });
  }

  function renderAddRow(groupName: string, category: string): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'camp-item camp-item--add';
    const form = document.createElement('form');
    form.className = 'camp-add-inline';
    const input = document.createElement('input');
    input.placeholder = '+ Add an item…';
    input.className = 'camp-input camp-input--sm';
    const btn = document.createElement('button');
    btn.type = 'submit';
    btn.textContent = 'Add';
    btn.className = 'camp-btn camp-btn--mustard camp-btn--sm';
    form.append(input, btn);
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = input.value.trim();
      addItem(groupName, category, name);
    });
    li.appendChild(form);
    return li;
  }

  function renderItemRow(item: Item): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'camp-item';

    const left = document.createElement('div');
    left.className = 'camp-item__left';

    const checkbox = document.createElement('input');
    checkbox.type = 'checkbox';
    checkbox.className = 'camp-item__checkbox';
    checkbox.title = 'Select for bulk claim';
    checkbox.checked = selectedItemIds.has(item.id);
    checkbox.addEventListener('change', () => {
      if (checkbox.checked) selectedItemIds.add(item.id);
      else selectedItemIds.delete(item.id);
      updateBulkBar();
    });
    left.appendChild(checkbox);

    const nameSpan = document.createElement('span');
    nameSpan.className = 'camp-item__name';
    nameSpan.textContent = item.name;
    left.appendChild(nameSpan);

    const editBtn = document.createElement('button');
    editBtn.type = 'button';
    editBtn.textContent = '✏️';
    editBtn.title = 'Edit item name';
    editBtn.className = 'camp-item__edit';
    editBtn.addEventListener('click', () => startEditingItem(item, nameSpan));
    left.appendChild(editBtn);

    const removeItemBtn = document.createElement('button');
    removeItemBtn.type = 'button';
    removeItemBtn.textContent = '✕';
    removeItemBtn.title = 'Remove this item from the checklist';
    removeItemBtn.className = 'camp-item__remove';
    removeItemBtn.addEventListener('click', () => {
      if (!confirm(`Remove "${item.name}"? This also clears anyone's claim on it.`)) return;
      li.classList.add('camp-removing');
      li.insertAdjacentHTML('beforeend', ' <span>🌧️</span>');
      setTimeout(() => removeItem(item), 380);
    });
    left.appendChild(removeItemBtn);

    const itemAssignments = assignments.filter((a) => a.item_id === item.id);
    itemAssignments.forEach((a, index) => {
      const chip = document.createElement('span');
      chip.className = 'camp-chip';
      chip.style.setProperty('--chip-rotate', index % 2 === 0 ? '-2deg' : '2deg');
      if (!previousAssignmentIds.has(a.id)) chip.classList.add('camp-chip--new');
      if (a.avatar) appendAvatar(chip, a.avatar, 'camp-chip-avatar');
      chip.appendChild(
        document.createTextNode(`🔥 ${a.person_name}` + (a.note ? ` — ${a.note}` : ''))
      );
      if (a.person_name.trim().toLowerCase() === myName.trim().toLowerCase()) {
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.textContent = '×';
        removeBtn.addEventListener('click', () => triggerRainRemoval(chip, a.id));
        chip.appendChild(removeBtn);
      }
      left.appendChild(chip);
    });

    const right = document.createElement('form');
    right.className = 'camp-claim-form';
    right.addEventListener('submit', (e) => {
      e.preventDefault();
      claimItem(item.id, noteInput.value.trim());
      noteInput.value = '';
    });
    const noteInput = document.createElement('input');
    noteInput.placeholder = 'note (optional)';
    noteInput.className = 'camp-input camp-input--sm';
    const claimBtn = document.createElement('button');
    claimBtn.type = 'submit';
    claimBtn.textContent = "🙋 I'll bring this";
    claimBtn.className = 'camp-btn camp-btn--mustard camp-btn--sm';
    right.appendChild(noteInput);
    right.appendChild(claimBtn);

    li.appendChild(left);
    li.appendChild(right);
    return li;
  }

  function renderSummary() {
    viewSummary.innerHTML = '';
    const byPerson = new Map<
      string,
      { assignmentId: string; itemName: string; note: string | null; avatar: string | null }[]
    >();
    for (const a of assignments) {
      const item = items.find((i) => i.id === a.item_id);
      if (!item) continue;
      const list = byPerson.get(a.person_name) ?? [];
      list.push({ assignmentId: a.id, itemName: item.name, note: a.note, avatar: a.avatar });
      byPerson.set(a.person_name, list);
    }
    if (byPerson.size === 0) {
      viewSummary.innerHTML =
        '<p class="text-[var(--camp-forest-deep)]">🌲 Nobody has claimed anything yet.</p>';
      return;
    }
    Array.from(byPerson.entries())
      .sort((a, b) => a[0].localeCompare(b[0]))
      .forEach(([person, claimed], index) => {
        const section = document.createElement('div');
        const heading = document.createElement('h3');
        heading.className = 'camp-summary-person';
        const avatar = claimed[0]?.avatar;
        if (avatar) {
          appendAvatar(heading, avatar, 'camp-avatar-icon');
        } else {
          heading.appendChild(document.createTextNode(FALLBACK_AVATAR_ICONS[index % FALLBACK_AVATAR_ICONS.length]));
        }
        heading.appendChild(document.createTextNode(person));
        section.appendChild(heading);
        const list = document.createElement('ul');
        list.className = 'camp-summary-list';
        for (const c of claimed) {
          const li = document.createElement('li');
          const textSpan = document.createElement('span');
          textSpan.textContent = c.itemName + (c.note ? ` — ${c.note}` : '');
          li.appendChild(textSpan);
          if (person.trim().toLowerCase() === myName.trim().toLowerCase()) {
            const removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.textContent = '✕';
            removeBtn.title = 'Remove this claim';
            removeBtn.className = 'camp-summary-item__remove';
            removeBtn.addEventListener('click', () => triggerRainRemoval(li, c.assignmentId));
            li.appendChild(removeBtn);
          }
          list.appendChild(li);
        }
        section.appendChild(list);
        viewSummary.appendChild(section);
      });
  }

  // --- Swipe mode ---
  //
  // Deck is built once per session (on first opening the tab, or on
  // restart) from *all* items regardless of the checklist's group filter —
  // Swipe mode is meant to blast through the whole list quickly. Skipping
  // an item only advances the local session's swipe order; it never
  // touches the database, so it's safe to restart as many times as you like.

  function shuffle<T>(arr: T[]): T[] {
    const copy = [...arr];
    for (let i = copy.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [copy[i], copy[j]] = [copy[j], copy[i]];
    }
    return copy;
  }

  function startSwipeDeck() {
    swipeDeck = shuffle(items);
    swipeIndex = 0;
    swipeInitialized = true;
    swipeBusy = false;
    renderSwipeMode();
  }

  swipeRestartBtn.addEventListener('click', () => startSwipeDeck());

  function updateSwipeProgress() {
    const total = swipeDeck.length;
    swipeProgress.textContent = total > 0 ? `${Math.min(swipeIndex, total)} / ${total}` : '';
  }

  function buildSwipeCard(item: Item, peek: boolean): HTMLElement {
    const card = document.createElement('div');
    card.className = peek ? 'camp-swipe-card camp-swipe-card--peek' : 'camp-swipe-card';
    card.dataset.itemId = item.id;

    const art = document.createElement('div');
    art.className = 'camp-swipe-card__art';
    const icon = document.createElement('img');
    icon.src = pickItemIconPath(item);
    icon.alt = '';
    icon.className = 'camp-swipe-card__icon';
    art.appendChild(icon);
    card.appendChild(art);

    const groupLine = document.createElement('div');
    groupLine.className = 'camp-swipe-card__group';
    groupLine.textContent =
      item.category !== item.group_name ? `${item.group_name} · ${item.category}` : item.group_name;
    card.appendChild(groupLine);

    const name = document.createElement('div');
    name.className = 'camp-swipe-card__name';
    name.textContent = item.name;
    card.appendChild(name);

    const claimants = document.createElement('div');
    claimants.className = 'camp-swipe-card__claimants';
    const itemAssignments = assignments.filter((a) => a.item_id === item.id);
    if (itemAssignments.length === 0) {
      const label = document.createElement('span');
      label.className = 'camp-swipe-card__claimants-label';
      label.textContent = 'Nobody has this yet';
      claimants.appendChild(label);
    } else {
      for (const a of itemAssignments) {
        const chip = document.createElement('span');
        chip.className = 'camp-chip';
        if (a.avatar) appendAvatar(chip, a.avatar, 'camp-chip-avatar');
        chip.appendChild(document.createTextNode(a.person_name));
        claimants.appendChild(chip);
      }
    }
    card.appendChild(claimants);

    const stampYes = document.createElement('div');
    stampYes.className = 'camp-swipe-card__stamp camp-swipe-card__stamp--yes';
    stampYes.textContent = "I'LL BRING IT";
    card.appendChild(stampYes);

    const stampNope = document.createElement('div');
    stampNope.className = 'camp-swipe-card__stamp camp-swipe-card__stamp--nope';
    stampNope.textContent = 'NOPE';
    card.appendChild(stampNope);

    if (!peek) attachDragHandlers(card, item, stampYes, stampNope);

    return card;
  }

  function attachDragHandlers(
    card: HTMLElement,
    item: Item,
    stampYes: HTMLElement,
    stampNope: HTMLElement
  ) {
    const threshold = 90;
    let dragging = false;
    let startX = 0;
    let startY = 0;
    let dx = 0;
    let dy = 0;

    function setStamps(currentDx: number) {
      stampYes.style.opacity = currentDx > 0 ? String(Math.min(currentDx / threshold, 1)) : '0';
      stampNope.style.opacity = currentDx < 0 ? String(Math.min(-currentDx / threshold, 1)) : '0';
    }

    card.addEventListener('pointerdown', (e: PointerEvent) => {
      if (swipeBusy) return;
      dragging = true;
      startX = e.clientX;
      startY = e.clientY;
      card.setPointerCapture(e.pointerId);
      card.style.transition = 'none';
    });

    card.addEventListener('pointermove', (e: PointerEvent) => {
      if (!dragging) return;
      dx = e.clientX - startX;
      dy = e.clientY - startY;
      card.style.transform = `translate(${dx}px, ${dy}px) rotate(${dx / 18}deg)`;
      setStamps(dx);
    });

    function onRelease() {
      if (!dragging) return;
      dragging = false;
      card.style.transition = 'transform 250ms ease, opacity 250ms ease';
      if (dx > threshold) {
        commitSwipe(card, item, 'right');
      } else if (dx < -threshold) {
        commitSwipe(card, item, 'left');
      } else {
        card.style.transform = 'translate(0, 0) rotate(0deg)';
        setStamps(0);
      }
      dx = 0;
      dy = 0;
    }

    card.addEventListener('pointerup', onRelease);
    card.addEventListener('pointercancel', onRelease);
  }

  function commitSwipe(card: HTMLElement, item: Item, direction: 'left' | 'right') {
    if (swipeBusy) return;
    swipeBusy = true;
    swipeNopeBtn.disabled = true;
    swipeYesBtn.disabled = true;
    const flyX = direction === 'right' ? 700 : -700;
    card.style.transition = 'transform 300ms ease, opacity 300ms ease';
    card.style.transform = `translate(${flyX}px, -30px) rotate(${direction === 'right' ? 22 : -22}deg)`;
    card.style.opacity = '0';
    card.style.pointerEvents = 'none';
    setTimeout(async () => {
      swipeIndex += 1;
      swipeBusy = false;
      swipeNopeBtn.disabled = false;
      swipeYesBtn.disabled = false;
      if (direction === 'right') {
        await claimItem(item.id, ''); // claimItem() re-renders via refreshAssignments()
      } else {
        renderSwipeMode();
      }
    }, 300);
  }

  swipeNopeBtn.addEventListener('click', () => {
    if (swipeBusy) return;
    const card = swipeStack.querySelector<HTMLElement>('.camp-swipe-card:not(.camp-swipe-card--peek)');
    const item = swipeDeck[swipeIndex];
    if (!card || !item) return;
    card.style.transition = 'transform 250ms ease, opacity 250ms ease';
    commitSwipe(card, item, 'left');
  });

  swipeYesBtn.addEventListener('click', () => {
    if (swipeBusy) return;
    const card = swipeStack.querySelector<HTMLElement>('.camp-swipe-card:not(.camp-swipe-card--peek)');
    const item = swipeDeck[swipeIndex];
    if (!card || !item) return;
    card.style.transition = 'transform 250ms ease, opacity 250ms ease';
    commitSwipe(card, item, 'right');
  });

  function renderSwipeMode() {
    if (!swipeInitialized) return;

    // Skip past any item that got deleted elsewhere mid-session.
    while (swipeIndex < swipeDeck.length && !items.find((i) => i.id === swipeDeck[swipeIndex].id)) {
      swipeIndex += 1;
    }

    updateSwipeProgress();
    swipeStack.innerHTML = '';

    if (swipeDeck.length === 0) {
      swipeActions.classList.add('hidden');
      swipeEnd.classList.remove('hidden');
      swipeEnd.querySelector('.camp-swipe-end__title')!.textContent = '🏕️ Nothing to swipe yet!';
      swipeEnd.querySelector('.camp-swipe-end__subtitle')!.textContent = 'Add some items to the checklist first.';
      swipeRestartBtn.classList.add('hidden');
      return;
    }

    if (swipeIndex >= swipeDeck.length) {
      swipeActions.classList.add('hidden');
      swipeEnd.classList.remove('hidden');
      swipeEnd.querySelector('.camp-swipe-end__title')!.textContent = "🎉 That's the whole deck!";
      swipeEnd.querySelector('.camp-swipe-end__subtitle')!.textContent = 'Want to play again?';
      swipeRestartBtn.classList.remove('hidden');
      return;
    }

    swipeEnd.classList.add('hidden');
    swipeActions.classList.remove('hidden');

    const next = swipeDeck[swipeIndex + 1];
    if (next) swipeStack.appendChild(buildSwipeCard(next, true));
    swipeStack.appendChild(buildSwipeCard(swipeDeck[swipeIndex], false));
  }

  function showDogToast() {
    const toast = document.createElement('div');
    toast.className = 'camp-swipe-toast';
    const img = document.createElement('img');
    img.src = ITEM_ICON_PATHS.dog;
    img.alt = '';
    toast.appendChild(img);
    const msg = document.createElement('p');
    msg.textContent = 'Wow, so creative! 🐶 (added to the checklist for real)';
    toast.appendChild(msg);
    swipeStack.appendChild(toast);
    setTimeout(() => toast.remove(), 1800);
  }

  swipeAddBtn.addEventListener('click', () => {
    swipeAddForm.classList.toggle('hidden');
    if (!swipeAddForm.classList.contains('hidden')) swipeAddInput.focus();
  });

  swipeAddForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = swipeAddInput.value.trim();
    if (!name) return;
    swipeAddInput.value = '';
    swipeAddForm.classList.add('hidden');
    await addItem('Misc.', 'Misc.', name);
    showDogToast();
  });

  // Auto-enter if a passcode is already stored from a previous visit.
  const stored = getStoredPasscode();
  if (stored) {
    tryEnter(stored).then((ok) => {
      if (!ok) clearStoredPasscode();
    });
  }
</script>
